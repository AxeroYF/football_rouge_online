{
  "name": "football-roguelite-simulator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node devtool/build.js",
    "demo": "node devtool/server.js",
    "public-demo": "node devtool/public-server.js",
    "tunnel": "node devtool/tunnel.js",
    "devtool": "node devtool/server.js",
    "simulate": "node src/cli.js --matches 10000 --seed demo",
    "balance:versus": "node versus/balance-report.js",
    "balance:versus:seeded": "node versus/balance-report.js --config=balance-config-seeded.json",
    "balance:versus:fast": "node versus/balance-report.js --config=balance-config-fast.json",
    "balance:versus:quick": "node versus/balance-report.js --quick",
    "balance:versus:render": "node versus/balance-report.js --render-only --quick",
    "traits": "node src/trait-cli.js --seed demo --role ST",
    "test": "node --test"
  }
}
